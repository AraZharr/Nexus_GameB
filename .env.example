# ============================================
# NEXUS BOARD - Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!

# --------------------------------------------
# Supabase (REQUIRED - Auth + Database)
# --------------------------------------------
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --------------------------------------------
# Firebase (OPTIONAL - for FCM push notifications)
# --------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# --------------------------------------------
# Cloudinary (REQUIRED for avatar/board upload)
# --------------------------------------------
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# --------------------------------------------
# Adsterra (OPTIONAL - for web ads)
# --------------------------------------------
VITE_ADSTERRA_SOCIAL_BAR_KEY=
VITE_ADSTERRA_POPUNDER_KEY=
VITE_ADSTERRA_NATIVE_KEY=
VITE_ADSTERRA_DIRECT_LINK=

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key_for_fcm_v1

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Adsterra (Web Ads)
VITE_ADSTERRA_SOCIAL_BAR_KEY=your_social_bar_key
VITE_ADSTERRA_POPUNDER_KEY=your_popunder_key
VITE_ADSTERRA_NATIVE_KEY=your_native_key
VITE_ADSTERRA_DIRECT_LINK=your_direct_link

# Optional: API Gateway
VITE_API_BASE_URL=https://api.nexusboard.app
